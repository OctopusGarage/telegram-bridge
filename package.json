{
  "name": "telegram-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.tests.json"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "grammy": "^1.42.0",
    "https-proxy-agent": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
