BOT_TOKEN=replace-me
TMUX_SESSION=telegram-bridge
TMUX_WINDOW=0
TMUX_PANE=0
POLL_INTERVAL_MS=1200
MAX_MESSAGE_LENGTH=3500
IDLE_POLL_TICKS=3
MAX_POLL_TICKS=20
HTTPS_PROXY=http://127.0.0.1:7890
# Comma-separated Telegram user IDs with access (leave empty to allow anyone — NOT recommended)
ALLOWED_USER_IDS=
# Max command length sent to tmux (default 5000)
MAX_COMMAND_LENGTH=5000
# Rate limit per user in ms (default 2000)
RATE_LIMIT_MS=2000
# Startup command sent by /startup
CLAUDE_STARTUP_COMMAND=
